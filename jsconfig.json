{
	"compilerOptions": {
		"checkJs": true,
		"target": "ESNext",
		"module": "esnext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"maxNodeModuleJsDepth": 0,
		"strict": false,
		"types": ["node"],
		"skipLibCheck": true
	},
	"include": ["source/**/*.mjs"],
}
